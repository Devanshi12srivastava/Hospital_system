<html lang="en">

  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>
      Appointment Confirmation
    </title>
  </head>

  <body
    style="
  margin:0;
  padding:0;
  background:#f4f7fb;
  font-family:Arial,sans-serif;
"
  >

    <!-- Main Wrapper -->
    <table
      width="100%"
      cellpadding="0"
      cellspacing="0"
      style="
      background:#f4f7fb;
      padding:20px 10px;
    "
    >

      <tr>
        <td align="center">

          <!-- Card -->
          <table
            width="100%"
            cellpadding="0"
            cellspacing="0"
            style="
            max-width:600px;
            background:#ffffff;
            border-radius:16px;
            overflow:hidden;
            box-shadow:
              0 4px 14px rgba(0,0,0,0.08);
          "
          >

            <!-- Header -->
            <tr>
              <td
                align="center"
                style="
                background:
                linear-gradient(
                  135deg,
                  #2563eb,
                  #1e40af
                );

                padding:40px 20px;
              "
              >

                <h1
                  style="
                color:white;
                margin:0;
                font-size:32px;
                font-weight:bold;
              "
                >
                  Appointment Confirmed
                </h1>

                <p
                  style="
                color:#dbeafe;
                margin-top:12px;
                font-size:16px;
              "
                >
                  Your healthcare appointment has been successfully booked
                </p>

              </td>
            </tr>

            <!-- Body -->
            <tr>
              <td
                style="
              padding:40px 30px;
            "
              >

                <h2
                  style="
                margin-top:0;
                color:#111827;
                font-size:28px;
              "
                >
                  Hello
                  {{patientName}}
                  👋
                </h2>

                <p
                  style="
                color:#4b5563;
                line-height:28px;
                font-size:16px;
              "
                >
                  Thank you for choosing our healthcare service. Your
                  appointment details are listed below.
                </p>

                <!-- Appointment Box -->
                <table
                  width="100%"
                  cellpadding="0"
                  cellspacing="0"
                  style="
                  margin-top:30px;
                  background:#f9fafb;
                  border-radius:12px;
                  border:1px solid #e5e7eb;
                "
                >

                  <tr>
                    <td
                      style="
                    padding:18px 20px;
                    border-bottom:
                    1px solid #e5e7eb;
                  "
                    >

                      <strong
                        style="
                      color:#111827;
                    "
                      >
                        Doctor
                      </strong>

                      <p
                        style="
                      margin:6px 0 0;
                      color:#4b5563;
                    "
                      >
                        {{doctorName}}
                      </p>

                    </td>
                  </tr>

                  <tr>
                    <td
                      style="
                    padding:18px 20px;
                    border-bottom:
                    1px solid #e5e7eb;
                  "
                    >

                      <strong
                        style="
                      color:#111827;
                    "
                      >
                        Appointment Date
                      </strong>

                      <p
                        style="
                      margin:6px 0 0;
                      color:#4b5563;
                    "
                      >
                        {{date}}
                      </p>

                    </td>
                  </tr>

                  <tr>
                    <td
                      style="
                    padding:18px 20px;
                  "
                    >

                      <strong
                        style="
                      color:#111827;
                    "
                      >
                        Appointment Time
                      </strong>

                      <p
                        style="
                      margin:6px 0 0;
                      color:#4b5563;
                    "
                      >
                        {{time}}
                      </p>

                    </td>
                    <p>
                      <b>Payment Status:</b>
                      <span style="color: orange;">
                        {{paymentStatus}}
                      </span>
                    </p>
                  </tr>

                </table>

                <!-- Button -->
                <table
                  width="100%"
                  cellpadding="0"
                  cellspacing="0"
                  style="
                  margin-top:35px;
                "
                >

                  <tr>

                  </tr>

                </table>

                <!-- Footer Text -->
                <p
                  style="
                margin-top:40px;
                color:#6b7280;
                line-height:26px;
                font-size:15px;
              "
                >
                  If you have any questions, feel free to contact our support
                  team anytime.
                </p>

              </td>
            </tr>

            <!-- Footer -->
            <tr>
              <td
                style="
              background:#111827;
              padding:25px;
              text-align:center;
            "
              >

                <p
                  style="
                margin:0;
                color:#d1d5db;
                font-size:14px;
              "
                >
                  © CareConnect
                </p>

              </td>
            </tr>

          </table>

        </td>
      </tr>

    </table>

  </body>

</html>